{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"skipLibCheck": true,
		"types": ["bun", "node"],
		"typeRoots": ["./node_modules/@types", "../app/node_modules/@types"]
	},
	"include": ["src", "tests"]
}
