{
	"name": "app",
	"version": "0.0.1",
	"description": "Electrobun app with React, Tailwind CSS v4, shadcn/ui, and Vite HMR",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build": "vite build && electrobun build",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "1.18.1",
		"lucide-react": "^1.23.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.0.0",
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"concurrently": "^9.1.0",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
